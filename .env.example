# ──────────────────────────────────────────────────────────────────────
# BeerID — example environment variables
#
# Скопируйте в `.env` и заполните реальными значениями:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────

# ── Runtime ────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Database (PostgreSQL обязательно для production) ───────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/beerid?schema=public
# Для dev/quickstart можно временно использовать SQLite:
# DATABASE_URL=file:./prisma/dev.db

# ── NextAuth (ОБЯЗАТЕЛЬНО для auth) ───────────────────────────────────
# Сгенерировать секрет: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# OAuth providers — минимум один (https://authjs.dev/getting-started/providers)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# ── Untappd API (https://untappd.com/api/docs) ────────────────────────
UNTAPPD_CLIENT_ID=
UNTAPPD_CLIENT_SECRET=

# ── Monitoring (опционально) ───────────────────────────────────────────
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# POSTHOG_KEY=

# ── Deploy ─────────────────────────────────────────────────────────────
SITE_ADDRESS=:81
PORT=3000
